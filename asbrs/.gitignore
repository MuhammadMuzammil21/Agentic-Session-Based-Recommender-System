# ── Virtual Environment ───────────────────────────────────────────────────────
.venv/
venv/
env/
ENV/

# ── Python ────────────────────────────────────────────────────────────────────
__pycache__/
*.py[cod]
*$py.class
*.pyo
*.pyd
*.egg
*.egg-info/
dist/
build/
.eggs/
pip-wheel-metadata/
*.whl

# ── Pytest / Coverage ─────────────────────────────────────────────────────────
.pytest_cache/
.coverage
.coverage.*
htmlcov/
coverage.xml
*.coveragerc

# ── Type checking ─────────────────────────────────────────────────────────────
.mypy_cache/
.pytype/
.pyre/

# ── Jupyter / IPython ─────────────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb

# ── Data ──────────────────────────────────────────────────────────────────────
data/raw/
data/processed/
*.csv
*.tsv
*.json.gz
*.parquet
*.arrow
*.pkl
*.pickle

# ── Model Checkpoints ─────────────────────────────────────────────────────────
checkpoints/*.pt
checkpoints/*.pth
checkpoints/*.bin
checkpoints/*.safetensors
# Keep .gitkeep so the directory is tracked
!checkpoints/.gitkeep

# ── HuggingFace cache ─────────────────────────────────────────────────────────
.cache/
~/.cache/huggingface/

# ── Logs ──────────────────────────────────────────────────────────────────────
*.log
logs/
runs/
wandb/
tensorboard/

# ── Environment / Secrets ─────────────────────────────────────────────────────
.env
.env.*
*.env
secrets.yaml
secrets.yml

# ── OS ────────────────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── IDE ───────────────────────────────────────────────────────────────────────
.vscode/
.idea/
*.sublime-project
*.sublime-workspace

# ── Misc ──────────────────────────────────────────────────────────────────────
*.tmp
*.bak
*.swp
*.swo
